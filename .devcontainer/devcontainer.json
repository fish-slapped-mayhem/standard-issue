// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/rust
{
  "name": "Devcontainer Devcontainer",
  // Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
  "image": "ghcr.io/fish-slapped-mayhem/devcontainer:base",

  // Use a named volume instead of your host folder
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.env"],
  // Set remote environment variables.
  "remoteEnv": {
    // Add local bin to PATH so that user-installed binaries are available
    "PATH": "${containerEnv:HOME}/.local/bin:/home/vscode/.local/bin:/usr/local/bin:${containerEnv:PATH}"
  },
  // Use 'mounts' to make the cargo cache persistent in a Docker Volume.
  // "mounts": [
  // 	{
  // 		"source": "devcontainer-cargo-cache-${devcontainerId}",
  // 		"target": "/usr/local/cargo",
  // 		"type": "volume"
  // 	}
  // ]
  "mounts": [
    // Mount the Docker socket to allow using Docker CLI inside the container
    // Do I need this AND docker-in-docker? Will this cause conflicts?
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],

  // Features to add to the dev container. More info: https://containers.dev/features.
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "moby": true,
      "installDockerBuildx": true,
      "installDockerComposeSwitch": true,
      "disableIp6tables": true,
      "version": "latest",
      "dockerDashComposeVersion": "v2"
    },
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "latest"
    }
  },

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  // "forwardPorts": [],

  // Use 'postCreateCommand' to run commands after the container is created.
  "postCreateCommand": {
    "SETUP KUBECONFIG": "mkdir -p /home/vscode/.kube && cp /workspaces/potential-fishstick/.devcontainer/.kubeconfig /home/vscode/.kube/config && chown -R vscode:vscode /home/vscode/.kube"
  },

  // Configure tool-specific properties.
  // "customizations": {},

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  "remoteUser": "vscode"
}
